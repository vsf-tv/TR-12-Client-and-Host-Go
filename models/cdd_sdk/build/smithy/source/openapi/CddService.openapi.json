            "EncryptionAes": {
                "oneOf": [
                    {
                        "type": "object",
                        "title": "aes128",
                        "properties": {
                            "aes128": {
                                "$ref": "#/components/schemas/EncryptionAes128"
                            }
                        },
                        "required": [
                            "aes128"
