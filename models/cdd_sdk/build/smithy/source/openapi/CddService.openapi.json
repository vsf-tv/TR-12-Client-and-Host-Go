                            }
                        },
                        "required": [
                            "aes256"
                        ]
                    }
                ]
            },
            "EncryptionAes128": {
                "type": "object",
                "properties": {
                    "passcode": {
                        "type": "string",
                        "maxLength": 32,
                        "minLength": 32,
                        "pattern": "^[a-fA-F0-9]+$",
                        "description": "A 32-character hexadecimal string."
                    }
                },
                "required": [
                    "passcode"
                ]
            },
            "EncryptionAes256": {
                "type": "object",
                "properties": {
                    "passcode": {
                        "type": "string",
                        "maxLength": 64,
                        "minLength": 64,
                        "pattern": "^[a-fA-F0-9]+$",
                        "description": "A 64-character hexadecimal string."
                    }
                },
                "required": [
                    "passcode"
                ]
            },
