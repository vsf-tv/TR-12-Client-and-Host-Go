                "responses": {
                    "200": {
                        "description": "Deprovision 200 response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DeprovisionResponseContent"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/disconnect": {
            "put": {
