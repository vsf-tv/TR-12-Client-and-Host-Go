# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
.vscode

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories
# vendor/

# Go workspace sum file (go.work is tracked)
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Built binaries — all go into bin/ directories, never tracked
client/bin/
host/bin/

# Proprietary device integrations — not part of the reference implementation
client/cmd/proprietary*/
client/proprietary*

console/
requirements/
deploy.sh

# Host configuration files (user-specific, only local_go_host.json is tracked)
client/host_configuration/dev_*.json
client/host_configuration/vsf_*.json
client/host_configuration/ec2_*.json

# SQLite database files
*.db
*.db-shm
*.db-wal
